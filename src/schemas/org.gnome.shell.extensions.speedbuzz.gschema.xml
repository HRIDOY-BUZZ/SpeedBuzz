<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.speedbuzz" path="/org/gnome/shell/extensions/speedbuzz/">
    <key name="use-bytes" type="b">
      <default>false</default>
      <summary>Use bytes/s instead of bps</summary>
    </key>
    <key name="show-colors" type="b">
      <default>false</default>
      <summary>Show colors in the label</summary>
    </key>
    <key name="position" type="s">
      <choices>
        <choice value="left"/>
        <choice value="center"/>
        <choice value="right"/>
      </choices>
      <default>'right'</default>
      <summary>Position of the indicator</summary>
    </key>
  </schema>
</schemalist>
